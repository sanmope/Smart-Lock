# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# --- PostgreSQL (operational) ---
POSTGRES_USER=smartlock
POSTGRES_PASSWORD=smartlock
POSTGRES_DB=smartlock

# --- PostgreSQL (data warehouse / Redshift local) ---
REDSHIFT_USER=redshift
REDSHIFT_PASSWORD=redshift
REDSHIFT_DB=smartlock_dw

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- S3 / LocalStack ---
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
S3_ENDPOINT=http://localstack:4566
S3_STAGING_BUCKET=smartlock-staging

# --- Computed (don't edit manually, these are derived) ---
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
REDSHIFT_JDBC_URL=jdbc:postgresql://redshift-local:5432/${REDSHIFT_DB}
